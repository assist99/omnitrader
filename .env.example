# =====================
# OmniTrader Environment
# =====================
# Copy this to .env and fill in your values
# This file is for docker-compose reference only
# Each service also has its own .env file

# Shared database path (relative to project root)
DATABASE_PATH=db/trading.db

# Shared encryption key for sensitive data
ENCRYPTION_KEY=ENCRYPTION_KEY_VALUE

# UI specific
JWT_SECRET=JWT_SECRET_KEY



# Database path
DATABASE_PATH=db/trading.db

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Bybit API defaults (for testnet)
BYBIT_TESTNET_API_URL=https://api-testnet.bybit.com
BYBIT_MAINNET_API_URL=https://api.bybit.com

# Scheduler configuration
SCHEDULE_PATTERN=0,15,30,45 * * * *

# Logging configuration
LOG_LEVEL=info
LOG_FILE=logs/trading-engine.log

# Engine configuration
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT_MS=30000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000