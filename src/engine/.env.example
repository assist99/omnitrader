# Copy this to .env.local and fill in your values
# Required for encryption/decryption
ENCRYPTION_KEY=your_encryption_key_here

# Database path
DATABASE_PATH=db/trading.db

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Note: TELEGRAM_USER_ID has been removed. Set Telegram User ID in the UI Settings page instead.
# Bybit API defaults (for testnet)
BYBIT_TESTNET_API_URL=https://api-testnet.bybit.com
BYBIT_MAINNET_API_URL=https://api.bybit.com

# Scheduler configuration
SCHEDULE_PATTERN=* * * *

# Logging configuration
LOG_LEVEL=info
LOG_FILE=logs/trading-engine.log

# Engine configuration
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT_MS=30000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
JWT_SECRET=your_jwt_secret_here
API_PORT=3001