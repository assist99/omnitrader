//@version=6
indicator("Triple Supertrend (Chart + HTF 1 + HTF 2) with Fills", overlay = true, timeframe = "", timeframe_gaps = true)

// ==========================================
// --- INPUTS ---
// ==========================================
gp_chart   = "1. Chart Supertrend Settings"
atrPeriod  = input.int(10,    "Chart ATR Length", minval = 1, group=gp_chart)
factor     = input.float(3.0, "Chart Factor",     minval = 0.01, step = 0.01, group=gp_chart)

gp_htf1     = "2. Higher Timeframe 1 Settings"
show_htf1   = input.bool(true, "Show HTF 1?", group=gp_htf1)
htf1_res    = input.string("60", title="HTF 1 Resolution", 
              options=["15", "30", "60", "120", "240", "D"], 
              tooltip="15=m15, 30=m30, 60=h1, 120=h2, 240=h4, D=d1", group=gp_htf1)
htf1_atr    = input.int(10,    "HTF 1 ATR Length", minval = 1, group=gp_htf1)
htf1_factor = input.float(3.0, "HTF 1 Factor",     minval = 0.01, step = 0.01, group=gp_htf1)

gp_htf2     = "3. Higher Timeframe 2 Settings"
show_htf2   = input.bool(true, "Show HTF 2?", group=gp_htf2)
htf2_res    = input.string("240", title="HTF 2 Resolution", 
              options=["15", "30", "60", "120", "240", "D"], 
              tooltip="15=m15, 30=m30, 60=h1, 120=h2, 240=h4, D=d1", group=gp_htf2)
htf2_atr    = input.int(10,    "HTF 2 ATR Length", minval = 1, group=gp_htf2)
htf2_factor = input.float(3.0, "HTF 2 Factor",     minval = 0.01, step = 0.01, group=gp_htf2)

// Global anchor for background fills
bodyMiddle = plot(barstate.isfirst ? na : (open + close) / 2, "Body Middle", display = display.none)

// Tuple calculation function helper
f_supertrend(f, a) =>
    [st, dir] = ta.supertrend(f, a)
    [st, dir]

// ==========================================
// 1. Chart Supertrend (Thin Lines: Thin Fills)
// ==========================================
[supertrend, direction] = ta.supertrend(factor, atrPeriod)
supertrend := barstate.isfirst ? na : supertrend

upTrend   = plot(direction < 0 ? supertrend : na, "Chart Up Trend",   color = color.green, style = plot.style_linebr, linewidth = 1)
downTrend = plot(direction < 0 ? na : supertrend, "Chart Down Trend", color = color.red,   style = plot.style_linebr, linewidth = 1)

fill(bodyMiddle, upTrend,   title = "Chart Uptrend background",   color = color.new(color.green, 90), fillgaps = false)
fill(bodyMiddle, downTrend, title = "Chart Downtrend background", color = color.new(color.red,   90), fillgaps = false)

// ==========================================
// 2. HTF 1 Supertrend (Medium Lines: Teal/Maroon)
// ==========================================
[htf1_st_raw, htf1_dir_raw] = request.security(syminfo.tickerid, htf1_res, f_supertrend(htf1_factor, htf1_atr), barmerge.gaps_on, barmerge.lookahead_off)

htf1_supertrend = ta.valuewhen(not na(htf1_st_raw), htf1_st_raw, 0)
htf1_direction  = ta.valuewhen(not na(htf1_dir_raw), htf1_dir_raw, 0)
htf1_supertrend := barstate.isfirst ? na : htf1_supertrend

// Conditional assignment based on the user toggle checkbox
htf1_plot_up   = show_htf1 and htf1_direction < 0 ? htf1_supertrend : na
htf1_plot_down = show_htf1 and htf1_direction >= 0 ? htf1_supertrend : na

htf1UpTrend   = plot(htf1_plot_up,   "HTF 1 Up Trend",   color = color.teal, style = plot.style_linebr, linewidth = 2)
htf1DownTrend = plot(htf1_plot_down, "HTF 1 Down Trend", color = color.maroon, style = plot.style_linebr, linewidth = 2)

fill(bodyMiddle, htf1UpTrend,   title = "HTF 1 Uptrend background",   color = color.new(color.teal, 93), fillgaps = false)
fill(bodyMiddle, htf1DownTrend, title = "HTF 1 Downtrend background", color = color.new(color.maroon, 93), fillgaps = false)

// ==========================================
// 3. HTF 2 Supertrend (Thick Lines: Blue/Orange)
// ==========================================
[htf2_st_raw, htf2_dir_raw] = request.security(syminfo.tickerid, htf2_res, f_supertrend(htf2_factor, htf2_atr), barmerge.gaps_on, barmerge.lookahead_off)

htf2_supertrend = ta.valuewhen(not na(htf2_st_raw), htf2_st_raw, 0)
htf2_direction  = ta.valuewhen(not na(htf2_dir_raw), htf2_dir_raw, 0)
htf2_supertrend := barstate.isfirst ? na : htf2_supertrend

// Conditional assignment based on the user toggle checkbox
htf2_plot_up   = show_htf2 and htf2_direction < 0 ? htf2_supertrend : na
htf2_plot_down = show_htf2 and htf2_direction >= 0 ? htf2_supertrend : na

htf2UpTrend   = plot(htf2_plot_up,   "HTF 2 Up Trend",   color = color.blue, style = plot.style_linebr, linewidth = 4)
htf2DownTrend = plot(htf2_plot_down, "HTF 2 Down Trend", color = color.orange, style = plot.style_linebr, linewidth = 4)

fill(bodyMiddle, htf2UpTrend,   title = "HTF 2 Uptrend background",   color = color.new(color.blue, 95), fillgaps = false)
fill(bodyMiddle, htf2DownTrend, title = "HTF 2 Downtrend background", color = color.new(color.orange, 95), fillgaps = false)

// ==========================================
// 4. Alerts (Based on Chart Frame)
// ==========================================
alertcondition(direction[1] > direction, title='Downtrend to Uptrend', message='The Supertrend value switched from Downtrend to Uptrend ')
alertcondition(direction[1] < direction, title='Uptrend to Downtrend', message='The Supertrend value switched from Uptrend to Downtrend')
alertcondition(direction[1] != direction, title='Trend Change', message='The Supertrend value switched from Uptrend to Downtrend or vice versa')