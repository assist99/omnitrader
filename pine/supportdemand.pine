//@version=6
indicator("Discretionary MTF Supply & Demand v7", overlay=true, max_boxes_count=500, max_labels_count=500)


// ==========================================
// 1. INPUTS & SETTINGS
// ==========================================
var string G_TF      = "Timeframe Activation"
show4H  = input.bool(true,  "Scan 4H Timeframe", group=G_TF)
show2H  = input.bool(true,  "Scan 2H Timeframe", group=G_TF)   // ADD THIS
show1H  = input.bool(true,  "Scan 1H Timeframe", group=G_TF)
show30m = input.bool(true,  "Scan 30m Timeframe", group=G_TF)
show15m = input.bool(false, "Scan 15m Timeframe", group=G_TF)
show5m  = input.bool(false, "Scan 5m Timeframe", group=G_TF)


checkBreakCandle2 = true
checkCandle0Dir   = input.bool(true, "Check Direction of Candle 0")


var string G_FILT    = "Pattern Filter Sensitivity"
bodyTolerance       = input.float(0.5, "Breakout Body Magnitude Multiplier", minval=0.0, maxval=5.0, step=0.1, group=G_FILT)
minWickOverlapRate  = input.float(0.1, "Minimum Wick Overlap Rate (0.0 - 1.0)", minval=0.0, maxval=1.0, step=0.05, group=G_FILT)


var string G_COLOR   = "Custom Color Theme Settings"
defDemandColor = input.color(#26a69a, "Demand Base Color", group=G_COLOR)
demandTransp   = input.int(92, "Demand Box Transparency (0-100)", minval=0, maxval=100, group=G_COLOR)
demandTextColor= input.color(color.white, "Demand Text Color", group=G_COLOR)


defSupplyColor = input.color(#ef5350, "Supply Base Color", group=G_COLOR)
supplyTransp   = input.int(92, "Supply Box Transparency (0-100)", minval=0, maxval=100, group=G_COLOR)
supplyTextColor= input.color(color.white, "Supply Text Color", group=G_COLOR)


var string G_DEAD    = "Dead/Broken Zone Visibility Options"
deadZoneHandleMode = input.string("Delete", "Broken Zone Action Mode", options=["Fade", "Delete"], group=G_DEAD)
deadZoneColor  = input.color(color.gray, "Broken Zone Color Theme", group=G_DEAD)
deadZoneTransp = input.int(96, "Broken Zone Box Transparency", minval=0, maxval=100, group=G_DEAD)


var string G_STYLE   = "Overlap Options"
overlapFilterMode   = input.string("Only High Timeframe", "Overlapped Zone Filter", options=["All", "Only High Timeframe", "Only Low Timeframe"], group=G_STYLE)


color demandBoxColor  = color.new(defDemandColor, demandTransp)
color supplyBoxColor  = color.new(defSupplyColor, supplyTransp)
color deadBoxColor    = color.new(deadZoneColor, deadZoneTransp)


// ==========================================
// 2. DYNAMIC SESSION TRACKING (2-DAY RETENTION)
// ==========================================
var int currentSessionOpenTime = na
var int lastSessionOpenTime    = na
var int expirySessionOpenTime  = na 


dayChanged = ta.change(time("D"))
if not na(dayChanged) and dayChanged > 0
    expirySessionOpenTime  := lastSessionOpenTime
    lastSessionOpenTime    := currentSessionOpenTime
    currentSessionOpenTime := time("D")


if na(lastSessionOpenTime) and not na(currentSessionOpenTime)
    lastSessionOpenTime := currentSessionOpenTime
if na(expirySessionOpenTime) and not na(lastSessionOpenTime)
    expirySessionOpenTime := lastSessionOpenTime


// ==========================================
// 3. TIMEFRAME COMPARISON UTILITIES
// ==========================================
getTfWeight(string tfName) =>
    switch tfName
        "4H"  => 240
        "2H"  => 120      // ADD THIS
        "1H"  => 60
        "30m" => 30
        "15m" => 15
        "5m"  => 5
        => 0


getChartTfWeight() =>
    timeframe.isminutes ? timeframe.multiplier : 
     timeframe.isdaily ? 1440 : 
     timeframe.isweekly ? 10080 : 
     timeframe.ismonthly ? 43200 : 999999


chartWeight = getChartTfWeight()
isChartDailyOrHigher = timeframe.isdaily or timeframe.isweekly or timeframe.ismonthly


// ==========================================
// 4. CORE LOGIC STRUCT & FUNCTION
// ==========================================
type Zone
    box   zoneBox
    line  midLine
    label zoneLabel
    float top
    float bottom
    int   startTime
    string tf
    int   tfWeight
    bool  isSupply
    bool  isLive
    bool  isDead       
    bool  isDisplayed


var Zone[] activeZones = array.new<Zone>()


processZones(string tfName, float o0, float o1, float o2, float c0, float c1, float c2, float h1, float h2, float l1, float l2, int targetTime) =>
    int currentTfWeight = getTfWeight(tfName)
    bool skipZoneCreation = isChartDailyOrHigher or (currentTfWeight < chartWeight)


    if not skipZoneCreation
        bool isSupTrend = (c1 < o1) 
        bool isDemTrend = (c1 > o1) 


        bool c0SupplyValid = not checkCandle0Dir or (c0 < math.min(l1,l2))
        bool c0DemandValid = not checkCandle0Dir or (c0 > math.max(h1,h2))


        float maxBody1 = math.max(o1, c1)
        float minBody1 = math.min(o1, c1)
        float maxBody2 = math.max(o2, c2)
        float minBody2 = math.min(o2, c2)
        float sizeBody2 = maxBody2 - minBody2


        float supTopWick = math.max(h2, h1)
        float supBotWick = math.max(maxBody2, maxBody1)
        float supZoneHeight = supTopWick - supBotWick


        bool supplyWicksOverlap = false
        if isSupTrend and supZoneHeight > 0
            bool rule1 = (h2 >= supBotWick) and (h1 >= supBotWick)
            bool rule2 = (h2 - supBotWick) >= (supZoneHeight * minWickOverlapRate)
            bool rule3 = (h1 - supBotWick) >= (supZoneHeight * minWickOverlapRate)
            if rule1 and rule2 and rule3
                supplyWicksOverlap := true
        else if isSupTrend and minWickOverlapRate == 0.0
            supplyWicksOverlap := true


        float demTopWick = math.min(minBody2, minBody1)
        float demBotWick = math.min(l2, l1)
        float demZoneHeight = demTopWick - demBotWick


        bool demandWicksOverlap = false
        if isDemTrend and demZoneHeight > 0
            bool rule1 = (l2 <= demTopWick) and (l1 <= demTopWick)
            bool rule2 = (demTopWick - l2) >= (demZoneHeight * minWickOverlapRate)
            bool rule3 = (demTopWick - l1) >= (demZoneHeight * minWickOverlapRate)
            if rule1 and rule2 and rule3
                demandWicksOverlap := true
        else if isDemTrend and minWickOverlapRate == 0.0
            demandWicksOverlap := true


        bool isSupplyConfirmed = supplyWicksOverlap and isSupTrend and (not checkBreakCandle2 or (c1 < (maxBody2 - (sizeBody2 * bodyTolerance)))) and c0SupplyValid
        bool isDemandConfirmed = demandWicksOverlap and isDemTrend and (not checkBreakCandle2 or (c1 > (minBody2 + (sizeBody2 * bodyTolerance)))) and c0DemandValid


        // Generate Supply Zone
        if isSupplyConfirmed
            string zoneLabelText = tfName + " Supply"
            box b = box.new(left=targetTime, top=supTopWick, right=time, bottom=supBotWick,
                             bgcolor=supplyBoxColor, border_color=color.new(color.black, 100),
                             border_style=line.style_solid, xloc=xloc.bar_time)
            float midPrice = (supTopWick + supBotWick) / 2
            line l = line.new(x1=targetTime, y1=midPrice, x2=time, y2=midPrice,
                              color=color.new(color.white, 50), style=line.style_dashed, xloc=xloc.bar_time)
            label lbl = label.new(x=time, y=midPrice, text=zoneLabelText,
                                  color=color.new(color.black, 100), textcolor=supplyTextColor,
                                  style=label.style_label_left, size=size.normal, xloc=xloc.bar_time)
            array.push(activeZones, Zone.new(b, l, lbl, supTopWick, supBotWick, targetTime, tfName, currentTfWeight, true, true, false, true))


        // Generate Demand Zone
        if isDemandConfirmed
            string zoneLabelText = tfName + " Demand"
            box b = box.new(left=targetTime, top=demTopWick, right=time, bottom=demBotWick,
                             bgcolor=demandBoxColor, border_color=color.new(color.black, 100),
                             border_style=line.style_solid, xloc=xloc.bar_time)
            float midPrice = (demTopWick + demBotWick) / 2
            line l = line.new(x1=targetTime, y1=midPrice, x2=time, y2=midPrice,
                              color=color.new(color.white, 50), style=line.style_dashed, xloc=xloc.bar_time)
            label lbl = label.new(x=time, y=midPrice, text=zoneLabelText,
                                  color=color.new(color.black, 100), textcolor=demandTextColor,
                                  style=label.style_label_left, size=size.normal, xloc=xloc.bar_time)
            array.push(activeZones, Zone.new(b, l, lbl, demTopWick, demBotWick, targetTime, tfName, currentTfWeight, false, true, false, true))


// ==========================================
// 5. GLOBAL DATA REQUESTS
// ==========================================
[o4H_0, o4H_1, o4H_2, c4H_0, c4H_1, c4H_2, h4H_1, h4H_2, l4H_1, l4H_2, t4H_2] = request.security(syminfo.tickerid, "240", [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)
[o2H_0, o2H_1, o2H_2, c2H_0, c2H_1, c2H_2, h2H_1, h2H_2, l2H_1, l2H_2, t2H_2] = request.security(syminfo.tickerid, "120", [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)  // ADD THIS
[o1H_0, o1H_1, o1H_2, c1H_0, c1H_1, c1H_2, h1H_1, h1H_2, l1H_1, l1H_2, t1H_2] = request.security(syminfo.tickerid, "60",  [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)
[o30_0, o30_1, o30_2, c30_0, c30_1, c30_2, h30_1, h30_2, l30_1, l30_2, t30_2] = request.security(syminfo.tickerid, "30",  [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)
[o15_0, o15_1, o15_2, c15_0, c15_1, c15_2, h15_1, h15_2, l15_1, l15_2, t15_2] = request.security(syminfo.tickerid, "15",  [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)
[o5_0,  o5_1,  o5_2,  c5_0,  c5_1,  c5_2,  h5_1,  h5_2,  l5_1,  l5_2,  t5_2]   = request.security(syminfo.tickerid, "5",   [open, open[1], open[2], close, close[1], close[2], high[1], high[2], low[1], low[2], time[2]], barmerge.gaps_off, barmerge.lookahead_off)


// Properly detect changes tracking differences via numerical series checks
change4H  = ta.change(t4H_2)
change2H  = ta.change(t2H_2)                                            // ADD THIS
change1H  = ta.change(t1H_2)
change30m = ta.change(t30_2)
change15m = ta.change(t15_2)
change5m  = ta.change(t5_2)


// ==========================================
// 6. EXECUTION MAP WITH ROLLING HISTORY FILTERING
// ==========================================
if barstate.isconfirmed
    if show4H == true and (change4H != 0 or na(change4H)) and (na(expirySessionOpenTime) or t4H_2 >= expirySessionOpenTime)
        processZones("4H",  o4H_0, o4H_1, o4H_2, c4H_0, c4H_1, c4H_2, h4H_1, h4H_2, l4H_1, l4H_2, t4H_2)
    if show2H == true and (change2H != 0 or na(change2H)) and (na(expirySessionOpenTime) or t2H_2 >= expirySessionOpenTime)  // ADD THIS
        processZones("2H",  o2H_0, o2H_1, o2H_2, c2H_0, c2H_1, c2H_2, h2H_1, h2H_2, l2H_1, l2H_2, t2H_2)  // ADD THIS
    if show1H == true and (change1H != 0 or na(change1H)) and (na(expirySessionOpenTime) or t1H_2 >= expirySessionOpenTime)
        processZones("1H",  o1H_0, o1H_1, o1H_2, c1H_0, c1H_1, c1H_2, h1H_1, h1H_2, l1H_1, l1H_2, t1H_2)
    if show30m == true and (change30m != 0 or na(change30m)) and (na(expirySessionOpenTime) or t30_2 >= expirySessionOpenTime)
        processZones("30m", o30_0, o30_1, o30_2, c30_0, c30_1, c30_2, h30_1, h30_2, l30_1, l30_2, t30_2)
    if show15m == true and (change15m != 0 or na(change15m)) and (na(expirySessionOpenTime) or t15_2 >= expirySessionOpenTime)
        processZones("15m", o15_0, o15_1, o15_2, c15_0, c15_1, c15_2, h15_1, h15_2, l15_1, l15_2, t15_2)
    if show5m == true and (change5m != 0 or na(change5m)) and (na(expirySessionOpenTime) or t5_2 >= expirySessionOpenTime)
        processZones("5m",  o5_0,  o5_1,  o5_2,  c5_0,  c5_1,  c5_2,  h5_1,  h5_2,  l5_1,  l5_2,  t5_2)


// ==========================================
// 7. REAL-TIME INVALIDATION ENGINE & OVERLAP FILTERS
// ==========================================
if array.size(activeZones) > 0
    for i = array.size(activeZones) - 1 to 0
        Zone currentZone = array.get(activeZones, i)
        bool isExpiredBySession = not na(expirySessionOpenTime) ? (currentZone.startTime < expirySessionOpenTime) : false
        
        if isExpiredBySession
            box.delete(currentZone.zoneBox)
            line.delete(currentZone.midLine)
            label.delete(currentZone.zoneLabel)
            array.remove(activeZones, i)
        else
            box.set_right(currentZone.zoneBox, time)
            line.set_x2(currentZone.midLine, time)
            label.set_x(currentZone.zoneLabel, time)
            
            if not currentZone.isDead
                bool supplyBreached = currentZone.isSupply and close > currentZone.top
                bool demandBreached = not currentZone.isSupply and close < currentZone.bottom
                
                if supplyBreached or demandBreached
                    if deadZoneHandleMode == "Delete"
                        box.delete(currentZone.zoneBox)
                        line.delete(currentZone.midLine)
                        label.delete(currentZone.zoneLabel)
                        array.remove(activeZones, i)
                    else
                        currentZone.isDead := true 


    if barstate.islast and array.size(activeZones) > 0
        for i = 0 to array.size(activeZones) - 1
            Zone cz = array.get(activeZones, i)
            cz.isDisplayed := true


        for i = 0 to array.size(activeZones) - 1
            Zone z1 = array.get(activeZones, i)
            if not z1.isDisplayed
                continue
            
            for j = 0 to array.size(activeZones) - 1
                if i == j
                    continue
                Zone z2 = array.get(activeZones, j)
                if not z2.isDisplayed
                    continue
                
                bool pricesOverlap = (z1.bottom < z2.top) and (z1.top > z2.bottom)
                
                if pricesOverlap
                    if z1.tf == z2.tf
                        if z1.startTime > z2.startTime
                            z1.isDisplayed := false
                            break
                    else if overlapFilterMode == "Only High Timeframe"
                        if z1.tfWeight < z2.tfWeight
                            z1.isDisplayed := false
                            break
                    else if overlapFilterMode == "Only Low Timeframe"
                        if z1.tfWeight > z2.tfWeight
                            z1.isDisplayed := false
                            break


        // Re-rendering loop with complete label cleaning protection
        for i = array.size(activeZones) - 1 to 0
            Zone cz = array.get(activeZones, i)
            if cz.isDisplayed
                color normalBoxColor = cz.isDead ? deadBoxColor : (cz.isSupply ? supplyBoxColor : demandBoxColor)
                color normalTxtColor = cz.isDead ? color.gray : (cz.isSupply ? supplyTextColor : demandTextColor)
                
                // Force absolute overwrite across drawing types to counter text layer blending
                box.set_bgcolor(cz.zoneBox, normalBoxColor)
                line.set_color(cz.midLine, cz.isDead ? color.new(color.gray, 80) : color.new(color.white, 50))
                label.set_textcolor(cz.zoneLabel, normalTxtColor)
            else
                // Hard delete both text drawing canvases and background wrappers to fully neutralize opacity gain
                box.delete(cz.zoneBox)
                line.delete(cz.midLine)
                label.delete(cz.zoneLabel)
                array.remove(activeZones, i)